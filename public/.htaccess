# ============================================================
# .htaccess — Ajnetpro — Export statique Next.js sur cPanel
# À placer dans public_html/ après upload du dossier /out
# ============================================================

Options -Indexes
RewriteEngine On

# --- Sécurité de base ---
Header always set X-Frame-Options "DENY"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set X-XSS-Protection "1; mode=block"

# --- Redirection HTTPS (décommenter si SSL actif sur cPanel) ---
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Redirection www → sans www (optionnel) ---
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# --- Redirection racine vers /fr ou /en selon la langue du navigateur ---
RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{HTTP:Accept-Language} ^fr [NC]
RewriteRule ^ /fr/ [L,R=302]

RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^ /fr/ [L,R=302]

# --- Support des URLs propres (sans .html) ---
# Next.js avec trailingSlash génère des dossiers index.html
# Les URLs /fr/ et /en/ fonctionnent nativement.

# --- Cache statique (performance) ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# --- Compression Gzip ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# --- Page d'erreur 404 ---
ErrorDocument 404 /404/index.html
